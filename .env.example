# MySQL connection string
# Buat database dulu, misal: CREATE DATABASE rekap_kegiatan;
# Catatan: jika password ada karakter spesial seperti @ atau #, wajib URL-encode.
# Contoh: @ -> %40, # -> %23, $ -> %24, ] -> %5D
DATABASE_URL="mysql://root:password@localhost:3306/rekap_kegiatan"

# JWT secret untuk session token (wajib diganti di produksi)
JWT_SECRET="change_me_to_a_long_random_string"

# Timeout query DB di login (ms).
# Default: production=20000, dev=8000
DB_TIMEOUT_MS=20000

# Maks jumlah file upload per kegiatan (dokumentasi + evidence).
# Default: 5
MAX_FILES_PER_ACTIVITY=5
